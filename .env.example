NODE_ENV=development
PORT=3000
ADMIN_PASSWORD=generated-by-installer
TOKEN_SECRET=generated-by-installer
WECHAT_TOKEN=
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_ADMIN_OPENIDS=
UPLOAD_DIR=/var/www/idbs/uploads
DATABASE_URL=postgresql://idbs_user:generated-by-installer@127.0.0.1:5432/idbs
PGSSL=false
PGSSL_REJECT_UNAUTHORIZED=true
PGSSL_CA=
CORS_ORIGIN=http://your-server-ip
TRUST_PROXY=false
# Use false only for isolated validation; production should keep scheduled maintenance and reports enabled.
ENABLE_SCHEDULERS=true
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW_MS=600000
API_RATE_LIMIT_MAX=120
API_RATE_LIMIT_WINDOW_MS=60000

# Database backup (npm run db:backup)
BACKUP_DIR=backups/db
BACKUP_RETENTION_DAYS=14
BACKUP_FORMAT=custom
# PG_DUMP_PATH=C:\\Program Files\\PostgreSQL\\16\\bin\\pg_dump.exe

# Production hardening notes:
# NODE_ENV=production
# TRUST_PROXY=true
# CORS_ORIGIN=https://your-lab-domain.example
# AUTH_RATE_LIMIT_MAX=5
# API_RATE_LIMIT_MAX=90

# PostgreSQL performance / observability
PGPOOL_MAX=10
PG_STATEMENT_TIMEOUT_MS=30000
PG_SLOW_QUERY_MS=200

# Orphan upload cleanup (npm run uploads:cleanup)
UPLOAD_ORPHAN_MAX_AGE_DAYS=30
