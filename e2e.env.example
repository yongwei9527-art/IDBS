# Dedicated database only. The runner rejects names without an "e2e" marker.
E2E_DATABASE_URL=postgresql://idbs_user:replace-with-test-password@127.0.0.1:55432/idbs_e2e

# Optional isolated runtime settings.
E2E_PORT=3100
E2E_PREPARE=true
E2E_BUILD=true
E2E_AUTH_RATE_LIMIT_MAX=1000
E2E_AUTH_RATE_LIMIT_WINDOW_MS=60000
E2E_API_RATE_LIMIT_MAX=5000
E2E_API_RATE_LIMIT_WINDOW_MS=60000